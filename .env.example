# Neo4j Aura Connection
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# Google AI API Key (for Gemini embeddings)
GOOGLE_API_KEY=your-google-api-key

# Groq API Key (for Llama/Qwen generation via OpenAI-compatible endpoint)
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# LiteLLM Proxy (for request/token/cost/latency observability via the admin UI).
# The proxy runs at http://localhost:4001 (see docker-compose.litellm.yml).
# LITELLM_MASTER_KEY is used both as admin login for /ui and as the API key
# Genkit sends to the proxy. LITELLM_SALT_KEY encrypts stored model creds in DB.
# Generate a random string for each (e.g. `openssl rand -hex 32`).
LITELLM_MASTER_KEY=sk-litellm-master-replace-me
LITELLM_SALT_KEY=replace-me-with-random-hex
LITELLM_BASE_URL=http://localhost:4001/v1
